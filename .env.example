# ---- Lead delivery (Resend) ----
# Create at https://resend.com/api-keys
RESEND_API_KEY=
# Inbox that receives contact leads.
MAIL_TO=poolsmithofflorida@gmail.com
# Verified Resend sender. onboarding@resend.dev only works in Resend test mode.
MAIL_FROM=Pool Smith <onboarding@resend.dev>

# ---- Cloudflare Turnstile (anti-spam) ----
# https://dash.cloudflare.com/?to=/:account/turnstile
# If TURNSTILE_SECRET_KEY is empty, verification is skipped (dev only).
# The site key is read server-side and passed into the form as a prop (no
# NEXT_PUBLIC_ needed). Always-pass TEST keys for local dev:
#   TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- Stripe (bill-pay on /payments) ----
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---- Misc ----
# Path to the SQLite leads file. Defaults to data/submissions.db (gitignored).
# SUBMISSIONS_DB_PATH=
